# LXMF Daemon configuration — Propagation Node
# Place this file at /etc/lxmd/config

[propagation]

  # Enable this instance as an LXMF Propagation Node.
  enable_node = yes

  # Announce the propagation node on the network at startup.
  announce_at_start = yes

  # Announce interval in minutes (360 = every 6 hours).
  announce_interval = 360

  # Automatically peer with other propagation nodes on the network.
  autopeer = yes

  # Maximum network depth for auto-peered nodes.
  autopeer_maxdepth = 6

  # Whether clients need to be in the "allowed" list to sync messages.
    # Set to yes and populate /etc/lxmd/allowed to restrict access.
  auth_required = no

  # Maximum message storage in megabytes.
  # message_storage_limit = 500


[lxmf]

  # Display name announced for this LXMF destination.
  display_name = LXMF Propagation Node

  # Announce the LXMF delivery destination at startup.
  announce_at_start = yes

  # Maximum accepted size for direct delivery transfers in kilobytes.
  delivery_transfer_max_accepted_size = 1000


[logging]

  # Log levels: 0=Critical, 1=Error, 2=Warning, 3=Notice, 4=Info, 5=Verbose, 6=Debug, 7=Extreme
  loglevel = 4
