# Reticulum Network Stack configuration
# Place this file at /var/lib/reticulum/rnsd/config

[reticulum]

  # Enable transport to route traffic for other peers,
  # pass announces and serve path requests.
  enable_transport = yes

  # Allow other local programs to share this Reticulum instance.
  share_instance = yes

  # Instance name for the shared instance socket.
  instance_name = default


[logging]

  # Log levels: 0=Critical, 1=Error, 2=Warning, 3=Notice, 4=Info, 5=Verbose, 6=Debug, 7=Extreme
  loglevel = 4


[interfaces]

  # This interface enables communication with other
  # link-local Reticulum nodes over UDP. It does not
  # need any functional IP infrastructure like routers
  # or DHCP servers, but will require that at least link-
  # local IPv6 is enabled in your operating system.
  [[Default Interface]]
    type = AutoInterface
    interface_enabled = True

  # This interface allows other Reticulum nodes to connect
  # to this instance over TCP. Enable it to accept inbound
  # connections from remote peers on port 4242.
  [[TCP Server Interface]]
    type = TCPServerInterface
    interface_enabled = False
    listen_ip = 0.0.0.0
    listen_port = 4242

  # Example: RNode LoRa interface (for RNode hardware).
  # Change `enabled` to `yes` and `port` to your RNode device.
  # Edit the LoRa parameters to match your community's conventions
  # and comply with local regulations.
  [[RNode LoRa]]
    type = RNodeInterface
    enabled = no
    port = /dev/ttyUSB0
    mode = access_point
    # LoRa parameters
    frequency = 869463000
    bandwidth = 125000
    spreadingfactor = 8
    codingrate = 6
    txpower = 22

  # Example: Connect to the RNS testnet over TCP.
  # Uncomment and modify to connect to a specific hub.
  # [[RNS Testnet Dublin]]
  #   type = TCPClientInterface
  #   interface_enabled = True
  #   target_host = dublin.connect.reticulum.network
  #   target_port = 4965
