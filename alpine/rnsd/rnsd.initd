#!/sbin/openrc-run

description="Reticulum Network Stack Daemon"

command="/usr/lib/rnsd/bin/rnsd"
command_args="--service --config /etc/reticulum"
command_user="rnsd:rnsd"
command_background=true
pidfile="/run/${RC_SVCNAME}.pid"

depend() {
    need net
    after firewall
}

start_pre() {
    checkpath --directory --owner root:root --mode 0777 /etc/reticulum/storage
    checkpath --directory --owner root:root --mode 0777 /etc/reticulum/interfaces
}